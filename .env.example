# Variáveis para o serviço Railway «billing-poller» (sem HTTP da API).
# Copiar para Variables do serviço ou usar Reference Variables da API.

# Obrigatório (mesmo Postgres da API)
DATABASE_URL=postgresql://user:pass@host:5432/aifactory

# Recomendado: mesma instância Redis da API (push billing no WebSocket)
REDIS_URL=redis://host:6379

# Descriptografar cursor_admin_api_key dos tenants
ENCRYPTION_KEY=32-char-minimum-secret-key-here!!

# Opcional — intervalo entre ticks (ms)
BILLING_CURSOR_POLL_INTERVAL_MS=5000
BILLING_MAX_MATCH_DELTA_MS=120000
CURSOR_USAGE_START_BUFFER_MS=120000
CURSOR_USAGE_END_BUFFER_MS=60000

# Local (API já em 4000): não definir PORT nem BILLING_POLLER_HEALTH_PORT — poller sem HTTP.
# Local com health à parte: BILLING_POLLER_HEALTH_PORT=4100
#
# Railway: PORT é injectado automaticamente para /health
